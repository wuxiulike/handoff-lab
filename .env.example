# Handoff Lab local configuration
#
# Copy this file to .env for your own notes if needed. The Flask app does not
# automatically load .env; set these variables in your shell or launcher.

HANDOFF_LAB_HOST=127.0.0.1
HANDOFF_LAB_PORT=51514

# Optional DeepSeek-compatible API settings used by dialogue/API features.
# Never commit real keys.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
REASONIX_MODEL=deepseek-v4-pro

# Optional Codex CLI/app-server controls.
# Leave empty to use the local Codex default profile/model.
CODEX_CLI=codex
OPENAI_PROFILE=
OPENAI_MODEL=
OPENAI_REASONING=default

# Optional Reasonix CLI override if the executable is not on PATH.
REASONIX_CLI=reasonix

# Optional visual QA model settings. Use an OpenAI-compatible endpoint when
# available; keep the real key in the named environment variable.
VISION_PROVIDER=openai-compatible
VISION_BASE_URL=
VISION_MODEL=
VISION_API_KEY=
